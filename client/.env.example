# Local development uses the Vite proxy, so VITE_WS_URL can be omitted locally.
# For a deployed frontend with a separate backend, set the real backend websocket URL.
# VITE_WS_URL=wss://your-backend-domain.com/ws
VITE_WS_URL=

# Used by the Vite dev proxy and as a fallback for websocket URL generation.
# Do not include /api. The app will convert https://your-backend.com to wss://your-backend.com/ws.
VITE_API_URL=http://localhost:8080
