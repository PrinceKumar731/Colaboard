# Local backend defaults
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# Use your deployed frontend origin in production, for example:
# FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Required only if/when auth is enabled again
JWT_SECRET=change-this-super-secret-key-change-this-super-secret-key
JWT_EXPIRATION_MINUTES=120
GOOGLE_CLIENT_ID=

# Required only if you add Spring JDBC/JPA persistence
DB_URL=
DB_USERNAME=
DB_PASSWORD=
